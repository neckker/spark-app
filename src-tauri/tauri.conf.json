{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "spark",
    "version": "0.3.4",
    "identifier": "spark.solyth.fun",
    "build": {
        "beforeDevCommand": "bun run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "bun run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Spark / тгк: @neckkero",
                "width": 500,
                "height": 900,

                "minWidth": 375,
                "minHeight": 450,

                "maxWidth": 750,
                "maxHeight": 1800
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "webviewInstallMode": {
                "type": "downloadBootstrapper"
            }
        },
        "createUpdaterArtifacts": true
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFERkU5QTlGNERCNUQ2NzUKUldSMTFyVk5uNXIrclpWZ1B1MTdnSEJaQ1lEbTJMZGp0Z1NrTHVPNnFCUEw0RFRKZFBSTzUxcjYK",
            "endpoints": [
                "https://github.com/solythbot/spark-updates/releases/latest/download/latest.json"
            ],
            "windows": {
                "installMode": "passive"
            }
        }
    }
}
