{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "spark",
    "version": "0.2.3",
    "identifier": "spark.solyth.fun",
    "build": {
        "beforeDevCommand": "bun run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "bun run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Spark / тгк: @zaitsev_DeFi",
                "width": 500,
                "height": 900,

                "minWidth": 375,
                "minHeight": 450,

                "maxWidth": 750,
                "maxHeight": 1800
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "webviewInstallMode": {
                "type": "downloadBootstrapper"
            }
        }
    }
}
